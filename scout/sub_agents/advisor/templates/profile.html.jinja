<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>My Profile · Job Market Scout</title>
<style>
  :root{
    --bg:#f6f7f9; --panel:#ffffff; --ink:#161a22; --muted:#697086;
    --line:#e7e9ee; --accent:#4f46e5; --accent-soft:#eef0fe; --radius:14px;
    --dot-on:#4f46e5; --dot-off:#e2e4ec;
  }
  *{box-sizing:border-box}
  body{margin:0;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    background:var(--bg);color:var(--ink);line-height:1.55;-webkit-font-smoothing:antialiased}
  a{color:inherit;text-decoration:none}
  .wrap{max-width:860px;margin:0 auto;padding:22px 20px 64px}
  .back{color:var(--muted);font-size:13px;display:inline-flex;gap:6px;margin-bottom:18px}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:20px 22px;margin-bottom:16px}
  .id{display:flex;gap:16px;align-items:center;flex-wrap:wrap}
  .avatar{width:56px;height:56px;border-radius:14px;background:var(--accent-soft);color:var(--accent);
    display:grid;place-items:center;font-size:22px;font-weight:700}
  h1{font-size:20px;margin:0;letter-spacing:-.02em}
  .role{color:var(--muted);font-size:14px}
  .note{font-size:12px;color:var(--muted);background:#fff9ec;border:1px solid #f2e4bf;
    border-radius:10px;padding:10px 12px;margin-top:14px}
  h2{font-size:13px;letter-spacing:.03em;text-transform:uppercase;color:var(--muted);margin:0 0 4px}
  .h2sub{font-size:12.5px;color:var(--muted);margin:0 0 16px}

  /* tech stack */
  .stackgrid{display:grid;grid-template-columns:1fr 1fr;gap:10px 26px}
  .cat{padding:10px 0;border-top:1px solid var(--line)}
  .cat:nth-child(1),.cat:nth-child(2){border-top:none;padding-top:0}
  .cat h3{font-size:12px;color:var(--muted);margin:0 0 10px;font-weight:600;letter-spacing:.02em}
  .tech{display:flex;align-items:center;justify-content:space-between;gap:10px;margin:7px 0}
  .tech .n{font-size:13.5px}
  .tech .n small{color:var(--muted);font-size:11.5px;margin-left:6px}
  .dots{display:flex;gap:3px;flex:0 0 auto}
  .dots i{width:8px;height:8px;border-radius:50%;background:var(--dot-off)}
  .dots i.on{background:var(--dot-on)}
  .legend{font-size:11.5px;color:var(--muted);margin-top:14px;display:flex;gap:16px;flex-wrap:wrap;
    border-top:1px solid var(--line);padding-top:12px}

  /* domain knowledge */
  .domains{display:flex;flex-direction:column;gap:14px}
  .domain{}
  .domainhead{display:flex;justify-content:space-between;align-items:baseline;gap:10px}
  .domain .t{font-size:14px;font-weight:600}
  .domain .lvl{font-size:11.5px;color:var(--muted)}
  .domain .d{font-size:12.5px;color:var(--muted);margin-top:3px}
  .bar{height:6px;border-radius:999px;background:#eef0f3;margin-top:8px;overflow:hidden}
  .bar > i{display:block;height:100%;background:linear-gradient(90deg,#6366f1,#4f46e5)}

  .kv{display:grid;grid-template-columns:150px 1fr;gap:8px 18px;font-size:14px}
  .kv .k{color:var(--muted)}
  .proj{padding:12px 0;border-top:1px solid var(--line)}
  .proj:first-child{border-top:none;padding-top:0}
  .proj .t{font-weight:600;font-size:14px}
  .proj .d{font-size:13px;color:var(--muted);margin-top:2px}
  .tags{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}
  .tag{font-size:11px;background:#f1f2f6;color:#5a6072;border-radius:6px;padding:3px 8px}
  .src{font-size:12px;color:var(--muted);margin-top:12px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace}
  @media(max-width:600px){ .stackgrid{grid-template-columns:1fr} .cat:nth-child(2){border-top:1px solid var(--line);padding-top:10px} .kv{grid-template-columns:1fr} }
</style>
</head>
<body>
<div class="wrap">
  <a class="back" href="history.html">‹ Back to reports</a>

  <div class="card">
    <div class="id">
      <div class="avatar">{{ profile.name[0]|upper }}</div>
      <div>
        <h1>{{ profile.name }}</h1>
        <div class="role">Target: {{ profile.target_role }} · {{ profile.target_locations|join(' / ') }}</div>
      </div>
    </div>
    <div class="note">This is what the agent matches jobs against. It's loaded from <code>profile.json</code> — the tech-stack proficiency and domain areas below drive gap detection.</div>
  </div>

  <div class="card">
    <h2>Tech stack</h2>
    <p class="h2sub">Self-rated proficiency. The Advisor compares these against each role's must-have / nice-to-have requirements.</p>
    <div class="stackgrid">
      {% for category in profile.tech_stack %}
      <div class="cat">
        <h3>{{ category.category|upper }}</h3>
        {% for skill in category.skills %}
        <div class="tech">
          <span class="n">{{ skill.name }}{% if skill.note %} <small>{{ skill.note }}</small>{% endif %}</span>
          <span class="dots">
            {% for i in range(1, 6) %}<i{% if i <= skill.proficiency %} class="on"{% endif %}></i>{% endfor %}
          </span>
        </div>
        {% endfor %}
      </div>
      {% endfor %}
    </div>
    <div class="legend">
      <span>●●●●● proficiency, 1–5</span>
    </div>
  </div>

  <div class="card">
    <h2>Domain knowledge</h2>
    <p class="h2sub">Problem areas that inform domain fit beyond raw skills.</p>
    <div class="domains">
      {% for domain in profile.domain_knowledge %}
      <div class="domain">
        <div class="domainhead"><span class="t">{{ domain.name }}</span><span class="lvl">{{ domain.level }}</span></div>
        <div class="d">{{ domain.description }}</div>
        <div class="bar"><i style="width:{{ domain.proficiency }}%"></i></div>
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="card">
    <h2>Background</h2>
    <div class="kv">
      <div class="k">Education</div><div>{{ profile.background.education }}</div>
      <div class="k">Experience</div><div>{{ profile.background.experience }}</div>
      <div class="k">Preferred roles</div><div>{{ profile.background.preferred_roles|join(', ') }}</div>
      <div class="k">Locations</div><div>{{ profile.background.locations|join(', ') }}</div>
    </div>
  </div>

  <div class="card">
    <h2>Projects</h2>
    {% for project in profile.projects %}
    <div class="proj">
      <div class="t">{{ project.title }}</div>
      <div class="d">{{ project.description }}</div>
      <div class="tags">{% for tag in project.tags %}<span class="tag">{{ tag }}</span>{% endfor %}</div>
    </div>
    {% endfor %}
    <div class="src">source: scout/profile.json</div>
  </div>
</div>
</body>
</html>
