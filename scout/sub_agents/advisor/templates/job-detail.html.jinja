<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ detail.listing.title }} · {{ detail.listing.company }} — Job Market Scout</title>
<style>
  :root{
    --bg:#f6f7f9; --panel:#ffffff; --ink:#161a22; --muted:#697086;
    --line:#e7e9ee; --accent:#4f46e5; --accent-soft:#eef0fe;
    --strong-bg:#e7f6ec; --strong-ink:#1c7c43; --strong-bar:#2fa866;
    --comp-bg:#fdf2df; --comp-ink:#9a6a10;
    --reach-bg:#fdecec; --reach-ink:#b23434;
    --radius:14px;
  }
  *{box-sizing:border-box}
  body{margin:0;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    background:var(--bg);color:var(--ink);line-height:1.55;-webkit-font-smoothing:antialiased}
  a{color:var(--accent);text-decoration:none}
  .wrap{max-width:820px;margin:0 auto;padding:22px 20px 64px}
  header.top{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:18px}
  .brand{display:flex;align-items:center;gap:10px;font-weight:700;letter-spacing:-.01em}
  .brand .dot{width:26px;height:26px;border-radius:8px;background:var(--accent);
    display:grid;place-items:center;color:#fff;font-size:15px}
  .nav{display:flex;gap:6px}
  .nav a{font-size:13px;color:var(--muted);padding:7px 12px;border-radius:9px}
  .nav a.active{color:var(--ink);background:var(--panel);border:1px solid var(--line)}
  .back{color:var(--muted);font-size:13px;display:inline-flex;gap:6px;margin-bottom:18px}
  .header{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:20px 22px}
  .row{display:flex;justify-content:space-between;gap:18px;align-items:flex-start;flex-wrap:wrap}
  h1{font-size:22px;margin:0 0 4px;letter-spacing:-.02em}
  .company{color:var(--muted);font-size:14px;display:flex;gap:8px;flex-wrap:wrap;align-items:center}
  .company .sep{opacity:.5}
  .apply{background:var(--accent);color:#fff;padding:10px 18px;border-radius:10px;font-size:14px;
    font-weight:600;white-space:nowrap}
  .metrics{display:flex;gap:14px;margin-top:18px;flex-wrap:wrap}
  .metric{flex:1 1 180px;border:1px solid var(--line);border-radius:12px;padding:14px 16px}
  .metric .k{font-size:12px;color:var(--muted)}
  .metric .v{font-size:26px;font-weight:700;letter-spacing:-.02em;margin-top:2px}
  .band-pill{display:inline-block;font-size:13px;font-weight:650;padding:4px 12px;border-radius:999px;
    margin-top:6px}
  .band-pill.strong{background:var(--strong-bg);color:var(--strong-ink)}
  .band-pill.comp{background:var(--comp-bg);color:var(--comp-ink)}
  .band-pill.reach{background:var(--reach-bg);color:var(--reach-ink)}
  .bar{height:8px;border-radius:999px;background:#eef0f3;margin-top:12px;overflow:hidden}
  .bar > i{display:block;height:100%;background:linear-gradient(90deg,#6366f1,#4f46e5)}
  .why{font-size:13.5px;color:#464b59;margin-top:12px}

  .snapshot{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);
    padding:16px 18px;margin-top:16px}
  .snapgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:14px}
  .snapgrid .k{font-size:11.5px;color:var(--muted)}
  .snapgrid .v{font-size:14px;font-weight:600;margin-top:2px}
  .about{font-size:13.5px;color:#464b59}
  .about > :first-child{margin-top:0}
  .about > :last-child{margin-bottom:0}
  .about p{margin:0 0 10px}
  .about ul,.about ol{margin:0 0 10px;padding-left:22px}
  .about li{margin:3px 0}
  .about strong{color:var(--ink)}
  .about a{word-break:break-word}
  .about h1,.about h2,.about h3,.about h4{font-size:14px;font-weight:650;margin:14px 0 6px;
    color:var(--ink);text-transform:none;letter-spacing:0}

  section{margin-top:26px}
  h2{font-size:15px;letter-spacing:.02em;text-transform:uppercase;color:var(--muted);margin:0 0 12px}

  .breakdown{display:flex;flex-direction:column;gap:14px;background:var(--panel);
    border:1px solid var(--line);border-radius:var(--radius);padding:16px 18px}
  .brkhead{display:flex;justify-content:space-between;align-items:baseline;font-size:13.5px}
  .brkhead .lab{font-weight:600}
  .brkhead .num{color:var(--muted);font-size:12.5px}
  .brk .track{height:7px;border-radius:999px;background:#eef0f3;margin-top:7px;overflow:hidden}
  .brk .track > i{display:block;height:100%;background:linear-gradient(90deg,#6366f1,#4f46e5)}
  .brk .track.low > i{background:linear-gradient(90deg,#e86a6a,#d14343)}
  .brk .note{font-size:12px;color:var(--muted);margin-top:5px}

  .reqs{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden}
  .reqcat{display:flex;align-items:center;justify-content:space-between;gap:10px;
    padding:11px 18px;background:#fafbfc;border-bottom:1px solid var(--line);border-top:1px solid var(--line)}
  .reqcat:first-child{border-top:none}
  .reqcat .name{font-size:11.5px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);font-weight:600}
  .reqcat .cov{font-size:11.5px;color:var(--muted)}
  .reqcat .cov b{color:var(--ink)}
  .req{display:flex;align-items:center;gap:12px;padding:12px 18px;border-bottom:1px solid var(--line);font-size:14px}
  .req:last-child{border-bottom:none}
  .req .mark{width:22px;height:22px;border-radius:6px;display:grid;place-items:center;font-size:13px;flex:0 0 auto}
  .req.have .mark{background:var(--strong-bg);color:var(--strong-ink)}
  .req.gap .mark{background:#fdecec;color:#b23434}
  .req .name{flex:1 1 auto}
  .req .tag{font-size:11px;color:var(--muted);border:1px solid var(--line);border-radius:6px;padding:2px 7px}
  .req .tag.must{color:#b23434;border-color:#f3caca;background:#fdf4f4}

  .coach{background:var(--accent-soft);border:1px solid #d9ddfb;border-radius:12px;padding:14px 16px;
    font-size:13.5px;color:#3b3f77;margin-bottom:16px}
  .gapblock{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);
    padding:16px 18px;margin-bottom:12px}
  .gaphead{display:flex;align-items:center;gap:10px}
  .gaphead .skill{font-weight:650;font-size:15px}
  .gaphead .must{font-size:11px;color:#b23434;background:#fdf4f4;border:1px solid #f3caca;
    border-radius:6px;padding:2px 7px}
  .gaphead .nice{font-size:11px;color:var(--muted);background:#f1f2f6;border:1px solid var(--line);
    border-radius:6px;padding:2px 7px}
  .no-gaps{font-size:13.5px;color:#464b59}
  .tips{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:16px 18px}
  .tips ol{margin:0;padding-left:20px;font-size:13.5px;color:#464b59}
  .tips li{margin:7px 0}
  .disclaimer{margin-top:26px;font-size:12px;color:var(--muted);background:var(--panel);
    border:1px dashed var(--line);border-radius:12px;padding:12px 14px}
  @media(max-width:600px){
    .apply{width:100%;text-align:center;margin-top:12px}
    .snapgrid{grid-template-columns:repeat(2,1fr)}
  }
</style>
</head>
<body>
<div class="wrap">
  <header class="top">
    <div class="brand"><span class="dot">◎</span> Job Market Scout</div>
    <nav class="nav">
      <a href="dashboard.html">Today</a>
      <a href="../history.html">History</a>
      {% if has_profile %}
      <a href="../profile.html">My Profile</a>
      {% else %}
      <span style="opacity:.4">My Profile</span>
      {% endif %}
    </nav>
  </header>

  <div class="header">
    <div class="row">
      <div>
        <h1>{{ detail.listing.title }}</h1>
        <div class="company">
          <strong>{{ detail.listing.company }}</strong><span class="sep">·</span>
          {{ detail.listing.location }}{% if detail.listing.is_remote %} (Remote){% endif %}<span class="sep">·</span>
          {{ detail.listing|format_salary }}
          {% if detail.listing.date_posted %}<span class="sep">·</span>Posted {{ detail.listing.date_posted.strftime('%d %b %Y') }}{% endif %}
        </div>
      </div>
      <a class="apply" href="{{ detail.listing.url }}" target="_blank" rel="noopener">View original listing ↗</a>
    </div>

    <div class="metrics">
      <div class="metric">
        <div class="k">Fit score</div>
        <div class="v">{{ detail.score }}<span style="font-size:14px;color:var(--muted)">/100</span></div>
        <div class="bar"><i style="width:{{ detail.score }}%"></i></div>
      </div>
      <div class="metric">
        <div class="k">Success band</div>
        <div class="band-pill {{ detail.band|band_css }}">{{ detail.band|band_label }}</div>
        <div class="why">{{ detail.reasoning }}</div>
      </div>
      <div class="metric">
        <div class="k">Must-have coverage</div>
        {% set must_reqs = detail.requirements|selectattr('requirement_level', 'equalto', 'must_have')|selectattr('kind', 'equalto', 'skill')|list %}
        {% set must_met = must_reqs|selectattr('met')|list %}
        <div class="v">{{ must_met|length }}<span style="font-size:14px;color:var(--muted)">/{{ must_reqs|length }}</span></div>
        <div class="why" style="margin-top:6px">
          {% if must_reqs %}
          {{ must_reqs|length - must_met|length }} must-have skill(s) missing.
          {% else %}
          No must-have requirements detected for this listing.
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  {% if detail.seniority or detail.work_type or detail.team %}
  <section>
    <h2>Role snapshot</h2>
    <div class="snapshot">
      <div class="snapgrid">
        {% if detail.seniority %}<div><div class="k">Seniority</div><div class="v">{{ detail.seniority }}</div></div>{% endif %}
        {% if detail.work_type %}<div><div class="k">Work type</div><div class="v">{{ detail.work_type }}</div></div>{% endif %}
        {% if detail.team %}<div><div class="k">Team</div><div class="v">{{ detail.team }}</div></div>{% endif %}
      </div>
    </div>
  </section>
  {% endif %}

  <section>
    <h2>About this role</h2>
    <div class="snapshot">
      <div class="about">{{ detail.listing.description | markdown }}</div>
    </div>
  </section>

  {% if detail.requirements %}
  <section>
    <h2>Why this band — match breakdown</h2>
    <div class="breakdown">
      {% if must_reqs %}
      <div class="brk">
        <div class="brkhead"><span class="lab">Tech stack fit (must-have)</span><span class="num">{{ must_met|length }} / {{ must_reqs|length }}</span></div>
        <div class="track{% if must_met|length < must_reqs|length %} low{% endif %}"><i style="width:{{ (must_met|length / must_reqs|length * 100)|round|int }}%"></i></div>
        <div class="note">{{ detail.reasoning }}</div>
      </div>
      {% endif %}
      {% set nice_reqs = detail.requirements|selectattr('requirement_level', 'equalto', 'nice_to_have')|selectattr('kind', 'equalto', 'skill')|list %}
      {% if nice_reqs %}
      {% set nice_met = nice_reqs|selectattr('met')|list %}
      <div class="brk">
        <div class="brkhead"><span class="lab">Nice-to-have coverage</span><span class="num">{{ nice_met|length }} / {{ nice_reqs|length }}</span></div>
        <div class="track"><i style="width:{{ (nice_met|length / nice_reqs|length * 100)|round|int }}%"></i></div>
        <div class="note">Bonus skills the listing calls out as preferred, not required.</div>
      </div>
      {% endif %}
    </div>
  </section>

  <section>
    <h2>Requirements vs your profile</h2>
    <div class="reqs">
      {% if must_reqs %}
      <div class="reqcat"><span class="name">Must-have skills</span><span class="cov"><b>{{ must_met|length }}</b>/{{ must_reqs|length }} met</span></div>
      {% for req in must_reqs %}
      <div class="req {% if req.met %}have{% else %}gap{% endif %}">
        <span class="mark">{% if req.met %}✓{% else %}✕{% endif %}</span>
        <span class="name">{{ req.skill }}</span>
        <span class="tag must">must-have</span>
      </div>
      {% endfor %}
      {% endif %}
      {% if nice_reqs %}
      <div class="reqcat"><span class="name">Nice-to-have skills</span><span class="cov"><b>{{ nice_met|length }}</b>/{{ nice_reqs|length }} met</span></div>
      {% for req in nice_reqs %}
      <div class="req {% if req.met %}have{% else %}gap{% endif %}">
        <span class="mark">{% if req.met %}✓{% else %}✕{% endif %}</span>
        <span class="name">{{ req.skill }}</span>
        <span class="tag">nice-to-have</span>
      </div>
      {% endfor %}
      {% endif %}
    </div>
  </section>
  {% endif %}

  {% set context_reqs = detail.requirements|rejectattr('kind', 'equalto', 'skill')|list %}
  {% if context_reqs %}
  {% set kind_labels = {'qualification': 'Qualification', 'experience': 'Experience', 'soft_skill': 'Soft skill'} %}
  <section>
    <h2>Role also asks for</h2>
    <div class="reqs">
      <div class="reqcat"><span class="name">Beyond technical skills</span><span class="cov">informational — not scored</span></div>
      {% for req in context_reqs %}
      <div class="req">
        <span class="name">{{ req.skill }}</span>
        <span class="tag">{{ kind_labels.get(req.kind, req.kind) }}</span>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  <section>
    <h2>Skill gaps to close</h2>
    {% if detail.gaps %}
    <div class="coach">
      Closing these gaps — especially the must-have ones — would meaningfully lift this candidacy.
    </div>
    {% for gap in detail.gaps %}
    <div class="gapblock">
      <div class="gaphead">
        <span class="skill">{{ gap.skill }}</span>
        {% if gap.requirement_level == 'must_have' %}
        <span class="must">must-have</span>
        {% else %}
        <span class="nice">nice-to-have</span>
        {% endif %}
      </div>
    </div>
    {% endfor %}
    {% else %}
    <div class="gapblock">
      <p class="no-gaps">No skill gaps detected for this role — your profile covers everything the agent flagged.</p>
    </div>
    {% endif %}
  </section>

  {% if detail.gaps %}
  <section>
    <h2>How to position your application</h2>
    <div class="tips">
      <ol>
        {% set must_gaps = detail.gaps|selectattr('requirement_level', 'equalto', 'must_have')|list %}
        {% if must_gaps %}
        <li>Prioritize <b>{{ must_gaps[0].skill }}</b> — it's the highest-impact gap since it's a must-have for this role.</li>
        {% if must_gaps|length > 1 %}
        <li>Also work toward: {{ must_gaps[1:]|map(attribute='skill')|join(', ') }} — the other missing must-have skill(s).</li>
        {% endif %}
        {% else %}
        <li>You cover every must-have skill this listing states — lead your application with those directly.</li>
        {% endif %}
        {% set nice_gaps = detail.gaps|selectattr('requirement_level', 'equalto', 'nice_to_have')|list %}
        {% if nice_gaps %}
        <li>{{ nice_gaps|map(attribute='skill')|join(', ') }} {% if nice_gaps|length == 1 %}is{% else %}are{% endif %} nice-to-have, not required — a line of familiarity is enough, don't over-invest before applying.</li>
        {% endif %}
      </ol>
    </div>
  </section>
  {% endif %}

  <div class="disclaimer">
    The <em>{{ detail.band|band_label }}</em> band is a rough estimate of fit, <strong>not a guarantee of an offer</strong>.
  </div>
</div>
</body>
</html>
