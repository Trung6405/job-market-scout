JOBSPY_MCP_URL=http://jobspy-mcp:9423
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek/deepseek-chat
SEARCH_ROLES=software engineer
SEARCH_LOCATIONS=Remote
RESULTS_WANTED=20
HOURS_OLD=72
SEARCH_SITE_NAMES=indeed,linkedin,zip_recruiter,glassdoor,google
RESUME_PATH=scout/resume.txt
PREFERRED_LOCATIONS=
REMOTE_ONLY=false
MIN_SALARY=
MIN_MATCH_SCORE=60
DESCRIPTION_CHAR_LIMIT=1500
DATABASE_URL=postgresql://scout:scout@localhost:5433/scout
BRIEFING_MAX_MATCHES=20
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_RECIPIENT=
# Optional: absolute path of this project's ./reports dir on the HOST
# machine, so the briefing email can link directly to the report instead
# of just showing its (container-relative) path as plain text.
REPORT_HOST_DIR=
# Optional: override the run date (YYYY-MM-DD) instead of using today's
# real UTC date. Useful for testing next-day tracker/report behavior
# without waiting for the clock to roll over.
RUN_DATE=
