JOBSPY_MCP_URL=http://jobspy-mcp:9423
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek/deepseek-chat
SEARCH_ROLES=software engineer
SEARCH_LOCATIONS=Remote
RESULTS_WANTED=20
HOURS_OLD=72
SEARCH_SITE_NAMES=indeed,linkedin,zip_recruiter,glassdoor,google
PREFERRED_LOCATIONS=
REMOTE_ONLY=false
MIN_SALARY=
MIN_MATCH_SCORE=60
DESCRIPTION_CHAR_LIMIT=1500
# Listings per model call (Scorer and Extractor separately). Lower these if
# a call fails with truncated/invalid JSON; raise to use fewer, larger calls.
SCORER_BATCH_SIZE=25
REQUIREMENTS_BATCH_SIZE=15
# Concurrent model calls in flight. Lower if you see 429 rate-limit errors.
MODEL_CONCURRENCY=3
# Output-token ceiling per model call. Headroom below deepseek-chat's 8192
# output cap so a batch response is less likely to truncate mid-JSON.
MODEL_MAX_TOKENS=8000
# Per-request timeout in seconds, so a hung provider call can't stall a stage.
MODEL_TIMEOUT_SECONDS=120
DATABASE_URL=postgresql://scout:scout@localhost:5433/scout
BRIEFING_MAX_MATCHES=20
# Days a listing may go unseen in a scrape before it's treated as closed.
LISTING_STALE_DAYS=7
# Discord bot that posts the daily briefing. Create a bot application at
# https://discord.com/developers, invite it to your server with the "Send
# Messages" permission, then set its token and the target channel's ID.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
