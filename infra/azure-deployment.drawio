        <mxCell id="n_nsg" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;NSG&lt;/b&gt; (scout-vm-nsg)&lt;br&gt;allow-ssh: TCP 22&lt;br&gt;from sshSourceAddressPrefix (default *)">
          <mxGeometry height="80" width="200" x="340" y="360" as="geometry" />
        </mxCell>

        <mxCell id="n_vnet" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#6c8ebf;verticalAlign=top;spacingTop=6;dashed=1;" value="&lt;b&gt;VNet scout-vm-vnet&lt;/b&gt; — 10.0.0.0/16">
          <mxGeometry height="470" width="560" x="600" y="180" as="geometry" />
        </mxCell>
        <mxCell id="n_subnet" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f7ff;strokeColor=#6c8ebf;verticalAlign=top;spacingTop=6;dashed=1;" value="&lt;b&gt;Subnet default&lt;/b&gt; — 10.0.0.0/24">
          <mxGeometry height="410" width="520" x="620" y="220" as="geometry" />
        </mxCell>
        <mxCell id="n_nic" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;NIC&lt;/b&gt; scout-vm-nic&lt;br&gt;(NSG attached, dynamic private IP)">
          <mxGeometry height="70" width="220" x="660" y="270" as="geometry" />
        </mxCell>
        <mxCell id="n_vm" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;spacingTop=6;" value="&lt;b&gt;VM scout-vm&lt;/b&gt; — Ubuntu 22.04, Standard_B2s">
          <mxGeometry height="240" width="480" x="640" y="370" as="geometry" />
        </mxCell>
        <mxCell id="n_docker" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;verticalAlign=top;spacingTop=6;dashed=1;" value="&lt;b&gt;Docker Compose bridge network&lt;/b&gt;">
          <mxGeometry height="150" width="440" x="660" y="440" as="geometry" />
        </mxCell>
        <mxCell id="n_c_app" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#82b366;" value="app :8000">
          <mxGeometry height="40" width="120" x="680" y="490" as="geometry" />
