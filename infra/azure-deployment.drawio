<mxfile host="app.diagrams.net" agent="job-market-scout/ak-cook" pages="2">
  <diagram id="deploy" name="1. Deployment (GitHub Actions)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="d_title" parent="1" vertex="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" value="Azure VM Deployment — CI/CD (GitHub Actions → single VM)">
          <mxGeometry height="30" width="620" x="340" y="20" as="geometry" />
        </mxCell>

        <mxCell id="d_dev" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Developer&lt;/b&gt;&lt;br&gt;git push to main">
          <mxGeometry height="60" width="150" x="40" y="200" as="geometry" />
        </mxCell>
        <mxCell id="d_cron" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 8;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;b&gt;Schedule&lt;/b&gt;&lt;br&gt;daily cron 21:00 UTC">
          <mxGeometry height="60" width="150" x="40" y="330" as="geometry" />
        </mxCell>

        <mxCell id="d_gha" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;spacingTop=6;" value="&lt;b&gt;GitHub Actions&lt;/b&gt; (.github/workflows)">
          <mxGeometry height="470" width="410" x="270" y="150" as="geometry" />
        </mxCell>
        <mxCell id="d_test" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;deploy.yml · test&lt;/b&gt;&lt;br&gt;pytest (Python 3.12)">
          <mxGeometry height="60" width="160" x="300" y="200" as="geometry" />
        </mxCell>
        <mxCell id="d_deploy" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;deploy.yml · deploy&lt;/b&gt;&lt;br&gt;checkout → rsync to VM&lt;br&gt;→ render .env → compose up">
          <mxGeometry height="80" width="160" x="300" y="290" as="geometry" />
        </mxCell>
        <mxCell id="d_runjob" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;scheduled-run.yml&lt;/b&gt;&lt;br&gt;SSH: docker compose&lt;br&gt;run --rm app">
          <mxGeometry height="80" width="160" x="490" y="290" as="geometry" />
        </mxCell>
        <mxCell id="d_secrets" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;🔒 Actions secrets&lt;/b&gt; (.env values + VM_SSH_PRIVATE_KEY)&lt;br&gt;+ vars: VM_HOST / VM_USER">
          <mxGeometry height="60" width="350" x="300" y="410" as="geometry" />
        </mxCell>
        <mxCell id="d_infra" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;infra-provision.yml&lt;/b&gt; (manual)&lt;br&gt;OIDC login → az deployment → main.bicep">
          <mxGeometry height="60" width="350" x="300" y="500" as="geometry" />
        </mxCell>

        <mxCell id="d_rg" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;spacingTop=6;dashed=1;" value="&lt;b&gt;Azure Resource Group&lt;/b&gt;">
          <mxGeometry height="470" width="440" x="760" y="150" as="geometry" />
        </mxCell>
        <mxCell id="d_vm" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;spacingTop=6;" value="&lt;b&gt;Ubuntu 22.04 VM (Standard_B2s)&lt;/b&gt; — Docker + Compose + rsync (cloud-init)">
          <mxGeometry height="320" width="400" x="780" y="200" as="geometry" />
        </mxCell>
        <mxCell id="d_app" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" value="app&lt;br&gt;(scout pipeline)">
          <mxGeometry height="50" width="150" x="800" y="250" as="geometry" />
        </mxCell>
        <mxCell id="d_mcp" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" value="jobspy-mcp&lt;br&gt;(:9423, docker.sock)">
          <mxGeometry height="50" width="150" x="990" y="250" as="geometry" />
        </mxCell>
        <mxCell id="d_pg" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" value="postgres:16&lt;br&gt;(volume)">
          <mxGeometry height="50" width="150" x="800" y="330" as="geometry" />
        </mxCell>
        <mxCell id="d_scraper" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#ffffff;strokeColor=#82b366;" value="jobspy (image)&lt;br&gt;docker run per search">
          <mxGeometry height="50" width="150" x="990" y="330" as="geometry" />
        </mxCell>
        <mxCell id="d_env" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="🔒 scout/.env (rendered at deploy time; rsync-excluded, never committed)">
          <mxGeometry height="50" width="360" x="800" y="410" as="geometry" />
        </mxCell>
        <mxCell id="d_deepseek" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="DeepSeek API">
          <mxGeometry height="50" width="140" x="780" y="560" as="geometry" />
        </mxCell>
        <mxCell id="d_gmail" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="Gmail SMTP">
          <mxGeometry height="50" width="140" x="1040" y="560" as="geometry" />
        </mxCell>

        <mxCell id="e2" parent="1" edge="1" source="d_dev" target="d_test" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;" value="push → CI">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" parent="1" edge="1" source="d_cron" target="d_runjob" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;dashed=1;" value="daily">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" parent="1" edge="1" source="d_test" target="d_deploy" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;" value="needs: test">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" parent="1" edge="1" source="d_secrets" target="d_deploy" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;dashed=1;endArrow=open;" value="env: secrets">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" parent="1" edge="1" source="d_deploy" target="d_vm" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;" value="rsync + SSH :22">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" parent="1" edge="1" source="d_runjob" target="d_vm" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;" value="SSH :22">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" parent="1" edge="1" source="d_infra" target="d_rg" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;dashed=1;" value="provisions (OIDC)">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" parent="1" edge="1" source="d_app" target="d_deepseek" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;dashed=1;endArrow=open;" value="scoring">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" parent="1" edge="1" source="d_app" target="d_gmail" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;dashed=1;endArrow=open;" value="briefing email">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="network" name="2. Network Topology">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n_title" parent="1" vertex="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" value="Azure Network Topology — VNet / Subnet / NSG / VM (defined in infra/main.bicep)">
          <mxGeometry height="30" width="760" x="270" y="20" as="geometry" />
        </mxCell>

        <mxCell id="n_internet" parent="1" vertex="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value="&lt;b&gt;Internet&lt;/b&gt;&lt;br&gt;(GitHub runner)">
          <mxGeometry height="80" width="160" x="60" y="230" as="geometry" />
        </mxCell>

        <mxCell id="n_rg" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;spacingTop=6;dashed=1;" value="&lt;b&gt;Resource Group&lt;/b&gt; (region: australiaeast)">
