  <diagram id="simple-journey" name="2. User Journey (Daily Run)">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="j_title" value="A day in the life — what happens on each daily run (top → bottom)" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="j1" value="&lt;b&gt;1. Scheduler&lt;/b&gt; starts the daily run  (planned)" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 8;strokeColor=#999999;fillColor=#f5f5f5;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="330" y="70" width="360" height="55" as="geometry" />
        </mxCell>
        <mxCell id="j2" value="&lt;b&gt;2. Scraper&lt;/b&gt; finds new job listings  (Job Boards + Web)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="330" y="155" width="360" height="55" as="geometry" />
        </mxCell>
        <mxCell id="j3" value="&lt;b&gt;3.&lt;/b&gt; New listings are saved to the database  (duplicates skipped)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="330" y="240" width="360" height="55" as="geometry" />
        </mxCell>
        <mxCell id="j4" value="&lt;b&gt;4. Scorer&lt;/b&gt; rates each job against your resume  (DeepSeek)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="330" y="325" width="360" height="55" as="geometry" />
        </mxCell>
        <mxCell id="j5" value="&lt;b&gt;5. Tracker&lt;/b&gt; marks each job: new / changed / closed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="330" y="410" width="360" height="55" as="geometry" />
        </mxCell>
        <mxCell id="j6" value="&lt;b&gt;6. Briefing&lt;/b&gt; writes the summary and emails it  (Gmail)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="330" y="495" width="360" height="55" as="geometry" />
        </mxCell>
        <mxCell id="j7" value="&lt;b&gt;7. Job Seeker&lt;/b&gt; reads the daily briefing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="330" y="580" width="360" height="55" as="geometry" />
        </mxCell>
        <mxCell id="j_legend" value="&lt;b&gt;Legend&lt;/b&gt;  Solid = built · Dashed = planned · Blue = our app · Orange = person" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;align=left;fontSize=11;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="330" y="665" width="360" height="40" as="geometry" />
        </mxCell>
        <mxCell id="j_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="j1" target="j2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="j_e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="j2" target="j3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="j_e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="j3" target="j4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="j_e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="j4" target="j5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="j_e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="j5" target="j6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="j_e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="j6" target="j7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="simple-deploy" name="3. Deployment">
    <mxGraphModel dx="1306" dy="930" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="d_title" value="How the app gets built and where it runs" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" parent="1" vertex="1">
