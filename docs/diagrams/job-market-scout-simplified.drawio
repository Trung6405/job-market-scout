          <mxGeometry height="120" width="180" x="600" y="360" as="geometry" />
        </mxCell>
        <mxCell id="d_legend" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;align=left;verticalAlign=top;fontSize=11;spacingLeft=6;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;Solid = built (Dockerfile + code in repo)&lt;br&gt;Dashed = planned (CI, scheduler, host, and Postgres not set up yet)" vertex="1">
