        <mxCell id="d_actions" value="&lt;b&gt;GitHub Actions&lt;/b&gt;&lt;br&gt;builds &amp; deploys the image (CI/CD)&lt;br&gt;(planned)" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 8;strokeColor=#999999;fillColor=#f5f5f5;fontColor=#666666;" parent="1" vertex="1">
