        <mxCell id="a_p3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="a_tracker" target="a_briefing" edge="1">
          <mxGeometry relative="1" as="geometry" />
